---
import CategorySummaryCard from '../components/CategorySummaryCard.astro';
import PostCard from '../components/PostCard.astro';
import RefractiveHomeActions from '../components/RefractiveHomeActions';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowUpRight } from 'lucide-react';
import { getPosts, getProjects } from '../lib/content';
import { getCategorySummaries } from '../lib/categorySummary';
import { formatCompactDate, SITE } from '../lib/site';

const posts = await getPosts();
const projects = await getProjects();
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const latestPosts = [
  ...featuredPosts,
  ...posts.filter((post) => !featuredPosts.some((featured) => featured.id === post.id)),
].slice(0, 3);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 2);
const categorySummaries = getCategorySummaries(posts);
const projectItems = (featuredProjects.length > 0 ? featuredProjects : projects).slice(0, 4);
const tagSummaries = Array.from(
  posts.reduce((tags, post) => {
    const freshnessDate = post.data.updated ?? post.data.published;
    post.data.tags.forEach((tag) => {
      const existing = tags.get(tag);
      tags.set(tag, {
        label: tag,
        count: (existing?.count ?? 0) + 1,
        latestDate: !existing || freshnessDate > existing.latestDate ? freshnessDate : existing.latestDate,
      });
    });
    return tags;
  }, new Map<string, { label: string; count: number; latestDate: Date }>()),
)
  .map(([, tag]) => tag)
  .sort((left, right) => right.count - left.count || right.latestDate.valueOf() - left.latestDate.valueOf())
  .slice(0, 10);
const giscusEnabled = Boolean(
  import.meta.env.PUBLIC_GISCUS_REPO &&
    import.meta.env.PUBLIC_GISCUS_REPO_ID &&
    import.meta.env.PUBLIC_GISCUS_CATEGORY &&
    import.meta.env.PUBLIC_GISCUS_CATEGORY_ID,
);
const reactionItems = posts.slice(0, 3);
const statusLabels = {
  'in-progress': '진행 중',
  shipped: '공개됨',
  archived: '보관됨',
};
---

<BaseLayout title="pistoslog" description={SITE.description}>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="eyebrow">Personal publishing space</p>
      <h1>
        <span>생각과 코드,</span>
        <span>일상을 오래 읽히는</span>
        <span>형태로 기록합니다.</span>
      </h1>
      <p>
        기술 공부와 개인 작업물, 생활 속 문장들을 한곳에 모으는 블로그입니다. 빠른 소식보다 다시 읽을 수 있는
        기록을 우선합니다.
      </p>
      <div class="hero-actions">
        <RefractiveHomeActions />
      </div>
    </div>

    <div class="hero-visual" aria-label="pistosmin profile">
      <div class="profile-card">
        <img src="https://github.com/pistosmin.png" alt="pistosmin GitHub profile" loading="eager" />
        <div>
          <strong>pistosmin</strong>
          <span>developer · maker · note taker</span>
        </div>
      </div>
      <div class="hero-index">
        {categorySummaries.map((summary) => <CategorySummaryCard summary={summary} variant="hero" />)}
      </div>
    </div>
  </section>

  <section class="content-band editorial-writing">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Writing</p>
        <h2>최근에 남긴 글</h2>
      </div>
      <a href="/writing/">전체 보기</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
    </div>
  </section>

  <section class="home-lower">
    <div class="tag-index-section">
      <div class="section-heading section-heading--compact">
        <div>
          <p class="eyebrow">Tags</p>
          <h2>태그 모아보기</h2>
        </div>
      </div>
      <div class="tag-cloud-panel" aria-label="글 태그 목록">
        {tagSummaries.map((tag) => (
          <span class="tag-token">
            <strong>#{tag.label}</strong>
            <small>아티클 {tag.count}개</small>
          </span>
        ))}
      </div>
    </div>

    <div class="reaction-panel">
      <div class="section-heading section-heading--compact">
        <div>
          <p class="eyebrow">Reactions</p>
          <h2>최근 반응</h2>
        </div>
      </div>
      <div class="reaction-list">
        {reactionItems.map((post) => (
          <a class="reaction-item" href={`/posts/${post.id}/#comments`}>
            <span>{giscusEnabled ? '댓글·공감' : '연동 대기'}</span>
            <strong>{post.data.title}</strong>
            <time datetime={(post.data.updated ?? post.data.published).toISOString()}>
              {formatCompactDate(post.data.updated ?? post.data.published)}
            </time>
          </a>
        ))}
      </div>
    </div>

    <div class="project-rail-section">
      <div class="section-heading section-heading--compact">
        <div>
          <p class="eyebrow">Projects</p>
          <h2>작업물</h2>
        </div>
        <a href="/projects/">전체 보기</a>
      </div>
      <div class="project-rail">
        {projectItems.map((project) => (
          <a class="project-peek" href={`/projects/${project.id}/`}>
            <span class="project-peek__status">{statusLabels[project.data.status]}</span>
            <strong>{project.data.title}</strong>
            <p>{project.data.description}</p>
            <span class="project-peek__stack">
              {project.data.stack.slice(0, 3).map((item) => <span>{item}</span>)}
            </span>
            <ArrowUpRight aria-hidden="true" size={16} />
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
