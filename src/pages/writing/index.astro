---
import CategorySummaryCard from '../../components/CategorySummaryCard.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts } from '../../lib/content';
import { getCategorySummaries } from '../../lib/categorySummary';
import { categoryMeta, type CategoryKey } from '../../lib/site';

const posts = await getPosts();
const categorySummaries = getCategorySummaries(posts);
const summaryByKey = new Map(categorySummaries.map((summary) => [summary.key, summary]));
const categoryGroups = Object.entries(categoryMeta)
  .map(([key, meta]) => ({
    key: key as CategoryKey,
    meta,
    posts: posts.filter((post) => post.data.category === key),
  }))
  .filter((group) => group.posts.length > 0);
---

<BaseLayout title="Writing" description="일상, 생각, 기술 공부와 작업 기록을 모아둔 글 목록.">
  <section class="page-hero page-hero--narrow">
    <p class="eyebrow">Writing</p>
    <h1>글 목록</h1>
    <p>완성된 생각과 공부 기록을 카테고리별로 모읍니다.</p>
    <div class="category-nav category-nav--summary">
      {categorySummaries.map((summary) => <CategorySummaryCard summary={summary} />)}
    </div>
  </section>

  {categoryGroups.map(({ key, meta, posts: grouped }) => {
    const summary = summaryByKey.get(key);
    return (
      <section class="content-band content-band--tight writing-category-section" id={key}>
        <div class="section-heading">
          <div>
            <p class="eyebrow">{meta.label}</p>
            <h2>{meta.description}</h2>
          </div>
          <div class="section-heading__meta">
            {summary?.isNew && <span class="section-heading__status">NEW</span>}
            <span>{summary?.countLabel ?? `${grouped.length}편`}</span>
            {summary?.latestDate && <time datetime={summary.latestDate.toISOString()}>업데이트 {summary.latestDateLabel}</time>}
          </div>
        </div>
        <div class="post-grid post-grid--list">
          {grouped.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    );
  })}
</BaseLayout>
