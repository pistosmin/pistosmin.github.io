---
import CategorySummaryCard from '../../components/CategorySummaryCard.astro';
import PostCard from '../../components/PostCard.astro';
import TagTokenList from '../../components/TagTokenList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategorySummaries } from '../../lib/categorySummary';
import { getPosts } from '../../lib/content';
import { getCategoryTagHref, getTagSummaries } from '../../lib/taxonomy';

export async function getStaticPaths() {
  const allPosts = await getPosts();
  const categorySummaries = getCategorySummaries(allPosts);

  return categorySummaries
    .filter((summary) => !summary.disabled)
    .map((summary) => ({
      params: { category: summary.key },
      props: {
        categorySummaries,
        posts: allPosts.filter((post) => post.data.category === summary.key),
        summary,
      },
    }));
}

const { categorySummaries, posts, summary } = Astro.props;
const tagSummaries = getTagSummaries(posts, {
  hrefForTag: ({ label }) => getCategoryTagHref(summary.key, label),
}).map((tag) => ({
  ...tag,
  href: `${tag.href}#writing-posts`,
}));
const archiveHash = '#writing-posts';
---

<BaseLayout title={`${summary.label} 글 목록`} description={`${summary.description} ${summary.countLabel}를 모아둔 목록.`}>
  <section class="writing-archive-layout">
    <div class="writing-archive-sidebar">
      <a class="back-link archive-back-link" href={`/writing/${archiveHash}`}>전체 글</a>
      <p class="eyebrow">Writing</p>
      <h1>{summary.label}</h1>
      <p>{summary.description}</p>
      <nav class="category-nav category-nav--summary" aria-label="글 카테고리 목록">
        {categorySummaries.map((item) => (
          <CategorySummaryCard summary={item} active={item.key === summary.key} href={`${item.href}${archiveHash}`} />
        ))}
      </nav>
      <div class="writing-tag-summary">
        <div class="writing-tag-summary__head">
          <strong>태그 모아보기</strong>
          <span>{summary.label} 글 기준 · 태그 {tagSummaries.length}개</span>
        </div>
        <TagTokenList tags={tagSummaries} ariaLabel={`${summary.label} 글 태그 목록`} />
      </div>
    </div>

    <section id="writing-posts" class="writing-archive-list" aria-labelledby="writing-posts-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{summary.label}</p>
          <h2 id="writing-posts-title">{summary.description}</h2>
        </div>
        <div class="section-heading__meta">
          {summary.isNew && <span class="section-heading__status">NEW</span>}
          <span>{summary.countLabel}</span>
          {summary.latestDate && <time datetime={summary.latestDate.toISOString()}>업데이트 {summary.latestDateLabel}</time>}
        </div>
      </div>
      <div class="post-grid post-grid--list">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  </section>
</BaseLayout>
