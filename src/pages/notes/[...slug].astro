---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, readingMinutes } from '../../lib/site';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <article class="article-shell article-shell--note">
    <header class="article-header">
      <a class="back-link" href="/notes/">Notes</a>
      <p class="eyebrow">Note</p>
      <h1>{note.data.title}</h1>
      <p>{note.data.description}</p>
      <div class="article-meta">
        <time datetime={note.data.published.toISOString()}>{formatDate(note.data.published)}</time>
        <span>{readingMinutes(note.body ?? '')}분 읽기</span>
      </div>
    </header>
    <div class="article-content" data-pagefind-body>
      <Content />
    </div>
  </article>
</BaseLayout>
