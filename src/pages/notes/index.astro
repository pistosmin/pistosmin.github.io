---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNotes } from '../../lib/content';
import { formatDate } from '../../lib/site';

const notes = await getNotes();
---

<BaseLayout title="Notes" description="짧은 생각과 공부 메모를 모아둔 페이지.">
  <section class="page-hero page-hero--narrow">
    <p class="eyebrow">Notes</p>
    <h1>짧은 기록</h1>
    <p>블로그 글이 되기 전의 메모와 가벼운 관찰을 남깁니다.</p>
  </section>

  <section class="timeline-list">
    {notes.map((note) => (
      <a class="timeline-item" href={`/notes/${note.id}/`}>
        <time datetime={note.data.published.toISOString()}>{formatDate(note.data.published)}</time>
        <strong>{note.data.title}</strong>
        <span>{note.data.description}</span>
      </a>
    ))}
  </section>
</BaseLayout>
