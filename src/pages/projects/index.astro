---
import ProjectCard from '../../components/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/content';
import { SITE } from '../../lib/site';

const projects = await getProjects();
const contributionChartUrl = 'https://ghchart.rshah.org/41584e/pistosmin';
---

<BaseLayout title="Projects" description="개인 작업물과 실험 프로젝트를 모아둔 페이지.">
  <section class="page-hero page-hero--narrow">
    <p class="eyebrow">Projects</p>
    <h1>작업물</h1>
    <p>만들고 배운 것들을 결과물과 맥락 중심으로 정리합니다.</p>
  </section>

  <section class="github-contribution-panel" aria-labelledby="github-contribution-title">
    <div class="github-contribution-panel__copy">
      <p class="eyebrow">GitHub</p>
      <h2 id="github-contribution-title">최근 1년 활동</h2>
      <p>공개 저장소에서 이어온 작업 흐름을 함께 봅니다.</p>
    </div>
    <div class="github-contribution-panel__visual">
      <img
        src={contributionChartUrl}
        alt="pistosmin GitHub 최근 1년 contribution 그래프"
        loading="lazy"
        decoding="async"
        width="830"
        height="128"
      />
    </div>
    <a class="github-contribution-panel__link" href={SITE.github} rel="me noreferrer" target="_blank">
      GitHub 프로필 보기
    </a>
  </section>

  <section class="project-grid project-grid--wide">
    {projects.map((project) => <ProjectCard project={project} />)}
  </section>
</BaseLayout>
