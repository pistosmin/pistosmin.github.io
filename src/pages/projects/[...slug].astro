---
import { getCollection, render } from 'astro:content';
import RefractiveActionLinks from '../../components/RefractiveActionLinks';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const links = Object.entries(project.data.links).filter(([, value]) => Boolean(value));
const actionLinks = links.map(([key, value]) => ({
  href: value as string,
  label: key,
  variant: 'ghost' as const,
}));
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <a class="back-link" href="/projects/">Projects</a>
      <p class="eyebrow">Project</p>
      <h1>{project.data.title}</h1>
      <p>{project.data.description}</p>
      <div class="article-meta">
        <time datetime={project.data.published.toISOString()}>{formatDate(project.data.published)}</time>
        {project.data.stack.map((item) => <span>{item}</span>)}
      </div>
      {links.length > 0 && (
        <div class="hero-actions">
          <RefractiveActionLinks items={actionLinks} />
        </div>
      )}
    </header>
    <div class="article-content" data-pagefind-body>
      <Content />
    </div>
  </article>
</BaseLayout>
