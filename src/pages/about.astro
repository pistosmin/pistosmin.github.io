---
import BaseLayout from '../layouts/BaseLayout.astro';
import RefractiveActionLinks from '../components/RefractiveActionLinks';
import { SITE } from '../lib/site';

const heroActions = [
  { href: SITE.github, label: 'GitHub', variant: 'primary' },
  { href: '/projects/', label: 'Projects', variant: 'ghost' },
] as const;
---

<BaseLayout title="About" description="pistosmin 소개와 관심사, 링크.">
  <section class="about-hero">
    <div>
      <p class="eyebrow">About</p>
      <h1>기록하면서 더 잘 만드는 개발자.</h1>
      <p>
        문제를 쪼개고, 배운 것을 남기고, 다시 사용할 수 있는 형태로 정리하는 일을 좋아합니다. 이 블로그는 일상과
        기술, 개인 프로젝트의 맥락을 함께 보여주는 공간입니다.
      </p>
      <div class="hero-actions">
        <RefractiveActionLinks items={heroActions} />
      </div>
    </div>
    <div class="about-card soft-panel">
      <img src="https://github.com/pistosmin.png" alt="pistosmin GitHub profile" />
      <strong>pistosmin</strong>
      <span>Software developer</span>
    </div>
  </section>

  <section class="resume-grid">
    <div class="soft-panel">
      <h2>관심사</h2>
      <p>프론트엔드 경험, 생산성 도구, 지식 관리, 개인화된 워크플로, AI를 활용한 개발 환경에 관심이 있습니다.</p>
    </div>
    <div class="soft-panel">
      <h2>기술 스택</h2>
      <div class="tag-row">
        <span>TypeScript</span>
        <span>React</span>
        <span>Astro</span>
        <span>Swift</span>
        <span>Python</span>
      </div>
    </div>
    <div class="soft-panel">
      <h2>블로그의 역할</h2>
      <p>완성된 이력서 한 줄보다 더 넓은 맥락을 보여주기 위해, 결과물과 그 과정에서 배운 것을 함께 기록합니다.</p>
    </div>
  </section>
</BaseLayout>
