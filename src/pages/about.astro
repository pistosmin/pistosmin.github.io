---
import BaseLayout from '../layouts/BaseLayout.astro';
import RefractiveActionLinks from '../components/RefractiveActionLinks';
import SocialProfileLinks from '../components/SocialProfileLinks';

const heroActions = [
  { href: '/projects/', label: '작업물 보기', variant: 'primary' },
] as const;
---

<BaseLayout title="About" description="pistoslog는 만든 것과 생각한 것을 다시 읽을 수 있게 남기는 개인 블로그입니다.">
  <section class="about-hero">
    <div>
      <p class="eyebrow">About</p>
      <h1>빠르게 만들고, 다시 읽을 수 있게 남깁니다.</h1>
      <p>
        pistosmin입니다. 레거시 RDB, 제한된 업무 환경, LLM/agent 도구처럼 빠르게 실험하되 조심해서 다뤄야 하는
        것들을 자주 만집니다. 새 도구는 빨리 써보는 편입니다. 그래도 내 작업에 남길 때는 다음에도 설명할 수
        있는 선택인지, 실제로 다시 돌려볼 수 있는지 먼저 봅니다.
      </p>
      <p>
        운영 데이터 앞에서는 답을 빨리 내는 것만큼 실행해도 되는 조건을 보는 편입니다. LLM 위키나 개인 블로그를
        만들 때도 그럴듯한 요약보다 어떤 원천을 보고 썼는지, 나중에 다시 읽어도 그때의 선택이 이해되는지를 더
        신경 씁니다.
      </p>
      <div class="hero-actions">
        <RefractiveActionLinks items={heroActions} />
      </div>
    </div>
    <div class="about-card soft-panel">
      <img src="https://github.com/pistosmin.png" alt="pistosmin GitHub profile" />
      <div class="about-card__body">
        <strong>pistosmin</strong>
        <span>기록을 남기며 도구를 만드는 개발자</span>
        <SocialProfileLinks />
      </div>
    </div>
  </section>

  <section class="about-stack soft-panel" aria-label="주로 쓰는 도구">
    <span>주로 쓰는 것들</span>
    <div>
      <span>Python</span>
      <span>TypeScript</span>
      <span>SQL/RDB</span>
      <span>React</span>
      <span>Spring Boot</span>
      <span>Elasticsearch</span>
      <span>Astro/MDX</span>
      <span>LLM tooling</span>
    </div>
  </section>
</BaseLayout>
