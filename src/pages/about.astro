---
import BaseLayout from '../layouts/BaseLayout.astro';
import RefractiveActionLinks from '../components/RefractiveActionLinks';
import { SITE } from '../lib/site';

const heroActions = [
  { href: SITE.github, label: 'GitHub', variant: 'primary' },
  { href: '/projects/', label: 'Projects', variant: 'ghost' },
] as const;
---

<BaseLayout title="About" description="pistoslog는 만든 것과 생각한 것을 다시 읽을 수 있게 남기는 개인 블로그입니다.">
  <section class="about-hero">
    <div>
      <p class="eyebrow">About</p>
      <h1>빠르게 만들고, 다시 읽을 수 있게 남깁니다.</h1>
      <p>
        pistosmin입니다. 레거시 RDB, 제한된 업무 환경, LLM/agent 도구처럼 빠르게 실험하되 조심해서 다뤄야 하는
        것들을 자주 만집니다. 새 도구는 빨리 써보는 편입니다. 그래도 내 작업에 남길 때는 다음에도 설명할 수
        있는 선택인지, 실제로 다시 돌려볼 수 있는지 먼저 봅니다.
      </p>
      <div class="hero-actions">
        <RefractiveActionLinks items={heroActions} />
      </div>
    </div>
    <div class="about-card soft-panel">
      <img src="https://github.com/pistosmin.png" alt="pistosmin GitHub profile" />
      <strong>pistosmin</strong>
      <span>기록을 남기며 도구를 만드는 개발자</span>
    </div>
  </section>

  <section class="resume-grid">
    <div class="soft-panel">
      <h2>요즘의 작업</h2>
      <p>
        운영 데이터 앞에서는 더 똑똑한 답보다 실행해도 되는 조건을 먼저 확인합니다. LLM 위키를 만들 때도
        그럴듯한 요약보다 어떤 원천을 보고 썼는지 남기는 쪽을 더 신경 씁니다. 개인 위키와 블로그는 같은 메모를
        다른 속도로 다루는 두 공간으로 나누어 쓰고 있습니다.
      </p>
    </div>
    <div class="soft-panel">
      <h2>남기는 기준</h2>
      <p>
        AI에게 넓은 초안을 맡기되, 마지막에는 사람이 줄입니다. 테스트가 붙는지, 로그가 남는지, 공개해도 되는지,
        다음 세션이 이어 읽을 수 있는지를 보면서 작업을 작게 다시 정리합니다.
      </p>
    </div>
    <div class="soft-panel">
      <h2>이 블로그</h2>
      <p>
        여기는 완성된 결과만 전시하는 곳은 아닙니다. 왜 그때 그 선택을 했는지, 어디서 과하게 벌어졌는지, 무엇을
        남기고 무엇을 버렸는지를 나중에도 이해할 수 있게 써두는 곳입니다.
      </p>
    </div>
  </section>
</BaseLayout>
