---
import SiteHeader from '../components/SiteHeader.astro';
import { SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  readPostSlug?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = `${SITE.url}/og-default.svg`,
  readPostSlug,
} = Astro.props;
const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
const needsProjectRailCacheFix = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, SITE.url)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} RSS`} href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, SITE.url)} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    {
      needsProjectRailCacheFix && (
        <link rel="stylesheet" href="/project-rail-hover-fix.css?v=20260506-3" />
      )
    }
    <script is:inline>
      const storedTheme = window.localStorage.getItem('theme');
      document.documentElement.dataset.theme = storedTheme || 'light';
    </script>
  </head>
  <body>
    <SiteHeader />
    <main id="content" data-current-post-slug={readPostSlug}>
      <slot />
    </main>
    <footer class="site-footer" data-pagefind-ignore>
      <div>
        <strong>{SITE.title}</strong>
        <p>생각, 일상, 기술, 작업물을 차분히 쌓아두는 곳.</p>
      </div>
      <nav aria-label="푸터 메뉴">
        <a href="/rss.xml">RSS</a>
        <a href={SITE.github}>GitHub</a>
        <a href="/about/">About</a>
      </nav>
    </footer>
    <script is:inline>
      (() => {
        const key = 'pistoslog.readPosts.v1';
        const maxEntries = 200;

        const getStorage = () => {
          try {
            return window.localStorage;
          } catch {
            return null;
          }
        };

        const readHistory = (storage) => {
          try {
            const raw = storage.getItem(key);
            if (!raw) return {};
            const parsed = JSON.parse(raw);
            if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};

            return Object.fromEntries(
              Object.entries(parsed).filter(
                ([slug, timestamp]) => typeof slug === 'string' && typeof timestamp === 'number',
              ),
            );
          } catch {
            return {};
          }
        };

        const writeHistory = (storage, history) => {
          try {
            const bounded = Object.fromEntries(
              Object.entries(history)
                .sort((left, right) => right[1] - left[1])
                .slice(0, maxEntries),
            );
            storage.setItem(key, JSON.stringify(bounded));
            return bounded;
          } catch {
            return history;
          }
        };

        const markCards = (history) => {
          document.querySelectorAll('[data-post-slug]').forEach((card) => {
            const slug = card.getAttribute('data-post-slug');
            if (slug && Object.prototype.hasOwnProperty.call(history, slug)) {
              card.setAttribute('data-read', 'true');
            }
          });
        };

        const storage = getStorage();
        if (!storage) return;

        const history = readHistory(storage);
        const currentSlug = document.getElementById('content')?.dataset.currentPostSlug;
        if (currentSlug) {
          history[currentSlug] = Date.now();
        }

        markCards(writeHistory(storage, history));
      })();
    </script>
  </body>
</html>
