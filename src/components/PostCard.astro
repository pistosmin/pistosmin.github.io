---
import type { CollectionEntry } from 'astro:content';
import { categoryMeta, formatDate } from '../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const category = categoryMeta[post.data.category];
---

<article class:list={['post-card', featured && 'post-card--featured']}>
  <a href={`/posts/${post.id}/`} class="post-card__link">
    <span class="post-card__category">{category.label}</span>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <div class="post-card__meta">
      <time datetime={post.data.published.toISOString()}>{formatDate(post.data.published)}</time>
      <span>{post.data.tags.slice(0, 3).join(' · ')}</span>
    </div>
  </a>
</article>
