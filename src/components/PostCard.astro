---
import type { CollectionEntry } from 'astro:content';
import { categoryMeta, formatDate } from '../lib/site';
import { getPostFreshnessDate } from '../lib/taxonomy';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const category = categoryMeta[post.data.category];
const displayDate = getPostFreshnessDate(post);
const isUpdated = Boolean(post.data.updated && post.data.updated.valueOf() !== post.data.published.valueOf());
const displayDateLabel = isUpdated ? `수정 ${formatDate(displayDate)}` : formatDate(displayDate);
---

<article class:list={['post-card', featured && 'post-card--featured']} data-post-slug={post.id}>
  <a href={`/posts/${post.id}/`} class="post-card__link">
    <div class="post-card__topline">
      <span class="post-card__category">{category.label}</span>
      <span class="post-card__read-badge">읽음</span>
    </div>
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <div class="post-card__meta">
      <time datetime={displayDate.toISOString()}>{displayDateLabel}</time>
      <span>{post.data.tags.slice(0, 3).join(' · ')}</span>
    </div>
  </a>
</article>
